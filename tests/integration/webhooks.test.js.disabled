/**
 * Integration tests for webhook endpoints
 */

import { describe, test, expect, beforeEach, jest } from '@jest/globals';
import request from 'supertest';
import { createApp } from '../../src/app.mjs';
import { initTestDatabase, seedTestDatabase, clearTestDatabase } from '../helpers/database.js';
import { testWhatsAppWebhooks, testStripeWebhooks } from '../fixtures/testData.js';

// Mock external services
jest.mock('../../src/services/whatsapp.mjs', () => ({
  sendWhatsAppText: jest.fn(() => Promise.resolve({ id: 'test-message-id' })),
  sendWhatsAppTemplate: jest.fn(() => Promise.resolve({ id: 'test-template-id' })),
  sendWhatsappImage: jest.fn(() => Promise.resolve({ id: 'test-image-id' }))
}));

jest.mock('../../src/services/ai.mjs', () => ({
  generateAiReply: jest.fn(() => Promise.resolve('Mocked AI response'))
}));

describe('Webhook Integration Tests', () => {
  let app;
  let testDb;
  const testUserId = 'test-user-123';

  beforeEach(async () => {
    // Initialize test database
    testDb = initTestDatabase();
    
    // Set the mocked database
    const { db } = require('../../src/db.mjs');
    Object.defineProperty(require('../../src/db.mjs'), 'db', {
      value: testDb,
      writable: true
    });
    
    // Seed test data
    seedTestDatabase(testDb, testUserId);
    
    // Create app instance
    app = createApp();
  });

  afterEach(() => {
    clearTestDatabase(testDb);
    cleanupTestDatabase();
  });

  describe('WhatsApp Webhook', () => {
    test('should handle message webhook verification', async () => {
      const verifyToken = 'test-verify-token';
      
      // Insert verify token into settings
      testDb.prepare(`
        UPDATE settings_multi SET verify_token = ? WHERE user_id = ?
      `).run(verifyToken, testUserId);

      const response = await request(app)
        .get('/webhook')
        .query({
          'hub.mode': 'subscribe',
          'hub.challenge': 'test-challenge',
          'hub.verify_token': verifyToken
        });

      expect(response.status).toBe(200);
      expect(response.text).toBe('test-challenge');
    });

    test('should reject invalid verify token', async () => {
      const response = await request(app)
        .get('/webhook')
        .query({
          'hub.mode': 'subscribe',
          'hub.challenge': 'test-challenge',
          'hub.verify_token': 'invalid-token'
        });

      expect(response.status).toBe(403);
    });

    test('should handle incoming message webhook', async () => {
      const webhookData = testWhatsAppWebhooks.message;
      
      const response = await request(app)
        .post('/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json');

      expect(response.status).toBe(200);
      
      // Check that message was stored in database
      const messages = testDb.prepare(`
        SELECT * FROM messages WHERE user_id = ? ORDER BY timestamp DESC LIMIT 1
      `).all(testUserId);
      
      expect(messages).toHaveLength(1);
      expect(messages[0].direction).toBe('inbound');
      expect(messages[0].text_body).toBe('Hello, I need help with my order');
    });

    test('should handle message status webhook', async () => {
      const webhookData = testWhatsAppWebhooks.status;
      
      const response = await request(app)
        .post('/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json');

      expect(response.status).toBe(200);
      
      // Check that status was stored
      const statuses = testDb.prepare(`
        SELECT * FROM message_statuses WHERE message_id = ?
      `).all('msg_inbound_123');
      
      expect(statuses).toHaveLength(1);
      expect(statuses[0].status).toBe('delivered');
    });

    test('should handle webhook signature verification', async () => {
      const webhookData = testWhatsAppWebhooks.message;
      const signature = 'sha256=test-signature';
      
      const response = await request(app)
        .post('/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json')
        .set('X-Hub-Signature-256', signature);

      // Should still process even with invalid signature in test mode
      expect(response.status).toBe(200);
    });
  });

  describe('Stripe Webhook', () => {
    test('should handle checkout session completed', async () => {
      const webhookData = testStripeWebhooks.checkoutCompleted;
      
      const response = await request(app)
        .post('/stripe/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json')
        .set('Stripe-Signature', 'test-signature');

      expect(response.status).toBe(200);
      
      // Check that user plan was updated
      const userPlan = testDb.prepare(`
        SELECT * FROM user_plans WHERE user_id = ?
      `).get(testUserId);
      
      expect(userPlan).toBeDefined();
    });

    test('should handle subscription updated', async () => {
      const webhookData = testStripeWebhooks.subscriptionUpdated;
      
      const response = await request(app)
        .post('/stripe/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json')
        .set('Stripe-Signature', 'test-signature');

      expect(response.status).toBe(200);
    });

    test('should reject webhook without signature', async () => {
      const webhookData = testStripeWebhooks.checkoutCompleted;
      
      const response = await request(app)
        .post('/stripe/webhook')
        .send(webhookData)
        .set('Content-Type', 'application/json');

      expect(response.status).toBe(400);
    });
  });

  describe('Health Check', () => {
    test('should return health status', async () => {
      const response = await request(app)
        .get('/health');

      expect(response.status).toBe(200);
      expect(response.body).toHaveProperty('status');
      expect(response.body).toHaveProperty('checks');
    });
  });

  describe('Metrics Endpoint', () => {
    test('should return metrics', async () => {
      const response = await request(app)
        .get('/metrics');

      expect(response.status).toBe(200);
      expect(response.body).toBeDefined();
    });
  });
});
