# =========================
# Core
# =========================
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-domain.com
LOG_LEVEL=info
STATIC_ASSETS_VERSION=

# =========================
# Debug/Diagnostics (keep off in prod)
# =========================
DEBUG_LOGS=0
DEBUG_BOOKINGS=0

# =========================
# Security
# =========================
SESSION_TOKEN_SECRET=change-me-strong-random
MEDIA_SIGN_SECRET=change-me-strong-random
MEDIA_SIGNING_DISABLED=0
WS_TOKEN_TTL_SECONDS=7200

# =========================
# Realtime (Ably)
# =========================
ABLY_API_KEY=
ABLY_TOKEN_TTL_MS=3600000

# =========================
# MongoDB
# =========================
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/whatsapp_agent
MONGODB_DB_NAME=whatsapp_agent

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================
# Outbound Queue (BullMQ) - requires Redis
# =========================
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=5

# =========================
# Webhook protections
# =========================
WEBHOOK_RATE_WINDOW_MS=15000
WEBHOOK_RATE_MAX=60
WEBHOOK_TENANT_LIMIT=120
WEBHOOK_TENANT_WINDOW=60

# =========================
# Auth (Clerk)
# =========================
CLERK_PUBLISHABLE=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=
CLERK_SIGN_UP_URL=

# =========================
# SMTP (Email)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# =========================
# Stripe (Payments)
# =========================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_SCOPE=read_write
STRIPE_CONNECT_REDIRECT_URL=
STRIPE_CONNECT_STATE_SECRET=
AGENT_PAYMENTS_DEFAULT_CURRENCY=usd
AGENT_PAYMENT_EXPIRES_MIN=30

# =========================
# AI (OpenAI)
# =========================
OPENAI_API_KEY=

# =========================
# Telemetry / Sentry / OTEL
# =========================
SENTRY_DSN=
SENTRY_RELEASE=whatsapp-agent@1.0.0
OTEL_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# =========================
# CDN (Optional)
# =========================
CDN_ENABLED=false
CDN_PROVIDER=cloudflare
CDN_DOMAIN=
CDN_OPTIMIZE_IMAGES=false
CDN_COMPRESSION=false
CDN_MINIFICATION=false

# =========================
# Vercel/Platform flags
# =========================
VERCEL=0

# =========================
# Local Dev Helpers (Optional)
# =========================
NGROK_URL=