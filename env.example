# Core
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:3000

# Security
SESSION_TOKEN_SECRET=change-me
MEDIA_SIGN_SECRET=change-me
MEDIA_SIGNING_DISABLED=0
WS_TOKEN_TTL_SECONDS=7200

# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp_agent
MONGODB_DB_NAME=whatsapp_agent

# Clerk (Auth)
CLERK_PUBLISHABLE=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_URL=
CLERK_SIGN_UP_URL=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Redis (Optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Webhook controls
WEBHOOK_RATE_WINDOW_MS=15000
WEBHOOK_RATE_MAX=60
WEBHOOK_TENANT_LIMIT=120
WEBHOOK_TENANT_WINDOW=60

# Scalability (Optional)
DATABASE_TYPE=mongodb
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# CDN (Optional)
CDN_ENABLED=false
CDN_PROVIDER=cloudflare
CDN_DOMAIN=
CDN_OPTIMIZE_IMAGES=false
CDN_COMPRESSION=false
CDN_MINIFICATION=false

# Realtime / Socket
SOCKET_MAX_CONNECTIONS_PER_USER=100

# Telemetry / Sentry / Vercel (Optional)
SENTRY_DSN=
VERCEL=
